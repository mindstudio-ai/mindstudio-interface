{
  "name": "@mindstudio-ai/interface",
  "version": "0.1.0",
  "description": "Frontend SDK for MindStudio v2 app interfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "husky && tsup",
    "prepublishOnly": "tsup",
    "lint:fix": "prettier --write ./src"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mindstudio",
    "interface",
    "frontend",
    "sdk"
  ],
  "homepage": "https://github.com/mindstudio-ai/mindstudio-interface#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindstudio-ai/mindstudio-interface.git"
  },
  "bugs": {
    "url": "https://github.com/mindstudio-ai/mindstudio-interface/issues"
  },
  "author": "MindStudio <support@mindstudio.ai> (https://mindstudio.ai)",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-curly": "^0.4.1",
    "tsup": "^8",
    "typescript": "^5.5"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
